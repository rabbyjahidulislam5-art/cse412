# ── Smart Campus App — Root Environment ────────────────────────
# Copy this file to .env and fill in values

# PostgreSQL
POSTGRES_USER=campus
POSTGRES_PASSWORD=campus_dev_2024
POSTGRES_DB=smart_campus

# JWT (generate with: openssl genrsa -out private.pem 2048)
JWT_ACCESS_SECRET=your-rs256-private-key-for-access-tokens
JWT_REFRESH_SECRET=your-rs256-private-key-for-refresh-tokens
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# OTP & QR Security
OTP_HMAC_SECRET=your-hmac-secret-for-otp-hashing
QR_HMAC_SECRET=your-hmac-secret-for-qr-signing

# Email (SMTP)
EMAIL_USER=smartcampus@ewubd.edu
EMAIL_PASS=your-email-app-password
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587

# SSLCommerz
SSLCOMMERZ_STORE_ID=your-sslcommerz-store-id
SSLCOMMERZ_PASSWORD=your-sslcommerz-password
SSLCOMMERZ_IS_LIVE=false

# bKash
BKASH_APP_KEY=your-bkash-app-key
BKASH_APP_SECRET=your-bkash-app-secret
BKASH_BASE_URL=https://tokenized.pay.bka.sh
BKASH_IS_LIVE=false

# Nagad
NAGAD_MERCHANT_ID=your-nagad-merchant-id
NAGAD_PUBLIC_KEY=your-nagad-public-key
NAGAD_PRIVATE_KEY=your-nagad-private-key
NAGAD_IS_LIVE=false

# Redis
REDIS_URL=redis://localhost:6379

# App
NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:3000
